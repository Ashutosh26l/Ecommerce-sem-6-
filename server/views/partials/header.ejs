<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title><%= typeof title !== 'undefined' ? title : 'Ecommerce' %></title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script>
      (function () {
        const storageKey = "theme";
        const root = document.documentElement;
        const savedTheme = localStorage.getItem(storageKey);
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const isDark = savedTheme ? savedTheme === "dark" : prefersDark;
        root.classList.toggle("dark", isDark);
        root.style.colorScheme = isDark ? "dark" : "light";
      })();
    </script>
    <script defer src="/js/theme.js"></script>
    <script defer src="/js/search.js"></script>
    <script defer src="/js/bootstrap-validation.js"></script>
    <style>
      :root {
        --dm-bg: #020617;
        --dm-surface: #0b1220;
        --dm-surface-2: #0f172a;
        --dm-surface-3: #111827;
        --dm-text-strong: #f8fafc;
        --dm-text: #dbe7ff;
        --dm-text-muted: #9fb0cc;
        --dm-border: #2b3a55;
        --dm-accent: #7db3ff;
        --dm-accent-strong: #9ec5ff;
      }
      .site-shell {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        font-family: "Plus Jakarta Sans", "Segoe UI", sans-serif;
      }
      .site-main {
        flex: 1;
      }
      html.dark body {
        background-color: var(--dm-bg);
        color: var(--dm-text);
      }
      html.dark h1,
      html.dark h2,
      html.dark h3,
      html.dark h4,
      html.dark h5,
      html.dark h6 {
        color: var(--dm-text-strong);
      }
      html.dark p,
      html.dark li,
      html.dark span,
      html.dark label,
      html.dark td,
      html.dark th {
        color: var(--dm-text);
      }
      html.dark a {
        color: var(--dm-accent);
      }
      html.dark a:hover {
        color: var(--dm-accent-strong);
      }
      html.dark .bg-white {
        background-color: var(--dm-surface-2) !important;
      }
      html.dark .bg-white\/95 {
        background-color: rgba(11, 18, 32, 0.92) !important;
      }
      html.dark .bg-slate-50 {
        background-color: var(--dm-bg) !important;
      }
      html.dark .bg-slate-100 {
        background-color: var(--dm-surface-3) !important;
      }
      html.dark .bg-slate-900 {
        background-color: var(--dm-surface) !important;
      }
      html.dark .bg-indigo-50,
      html.dark .bg-rose-50,
      html.dark .bg-emerald-100 {
        background-color: #142033 !important;
      }
      html.dark .text-slate-900 {
        color: var(--dm-text-strong) !important;
      }
      html.dark .text-slate-700,
      html.dark .text-slate-600,
      html.dark .text-slate-500 {
        color: var(--dm-text) !important;
      }
      html.dark .text-slate-400 {
        color: var(--dm-text-muted) !important;
      }
      html.dark .text-gray-900 {
        color: var(--dm-text-strong) !important;
      }
      html.dark .text-gray-500 {
        color: var(--dm-text-muted) !important;
      }
      html.dark .text-indigo-700,
      html.dark .text-indigo-600,
      html.dark .text-indigo-200,
      html.dark .text-indigo-100,
      html.dark .text-cyan-200 {
        color: var(--dm-accent-strong) !important;
      }
      html.dark .text-rose-600 {
        color: #ff9aa7 !important;
      }
      html.dark .text-emerald-700,
      html.dark .text-emerald-600 {
        color: #86efac !important;
      }
      html.dark .text-yellow-400,
      html.dark .text-amber-500 {
        color: #fcd34d !important;
      }
      html.dark .border-slate-200,
      html.dark .border-slate-300,
      html.dark .border-slate-700 {
        border-color: var(--dm-border) !important;
      }
      html.dark .border-rose-200,
      html.dark .border-emerald-200 {
        border-color: #3b4c68 !important;
      }
      html.dark input,
      html.dark select,
      html.dark textarea {
        background-color: var(--dm-surface) !important;
        color: var(--dm-text-strong) !important;
        border-color: var(--dm-border) !important;
      }
      html.dark input::placeholder,
      html.dark textarea::placeholder {
        color: var(--dm-text-muted);
      }
      html.dark .hover\:text-indigo-600:hover {
        color: var(--dm-accent-strong) !important;
      }
      html.dark .bg-indigo-600,
      html.dark .bg-indigo-500,
      html.dark .bg-indigo-400 {
        background-color: #2f5eaa !important;
      }
      html.dark .hover\:bg-indigo-700:hover {
        background-color: #3b6bb6 !important;
      }
      .theme-toggle {
        border: 0;
        background: transparent;
        padding: 0;
      }
      .theme-toggle-track {
        width: 74px;
        height: 38px;
        border-radius: 9999px;
        background: #e5e7eb;
        border: 1px solid #cbd5e1;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 10px;
        position: relative;
        transition: background-color 180ms ease, border-color 180ms ease;
      }
      .theme-toggle-thumb {
        position: absolute;
        top: 3px;
        left: 3px;
        width: 30px;
        height: 30px;
        border-radius: 9999px;
        background: #3244aa;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #ffffff;
        font-size: 16px;
        line-height: 1;
        box-shadow: 0 2px 6px rgba(15, 23, 42, 0.25);
        transition: transform 180ms ease, background-color 180ms ease;
      }
      .theme-toggle-icons {
        width: 100%;
        display: flex;
        justify-content: space-between;
        font-size: 16px;
        line-height: 1;
        color: #6b7280;
      }
      html.dark .theme-toggle {
        background: transparent;
      }
      html.dark .theme-toggle-track {
        background: #111827;
        border-color: #1f2937;
      }
      html.dark .theme-toggle-thumb {
        transform: translateX(36px);
        background: #3244aa;
      }
      html.dark .theme-toggle-icons {
        color: #9ca3af;
      }
    </style>
  </head>
  <body class="bg-slate-50 text-slate-900">
    <div class="site-shell">
      <header class="sticky top-0 z-40 border-b border-slate-200 bg-white/95 backdrop-blur">
        <div class="max-w-6xl mx-auto px-4 sm:px-6">
          <div class="h-16 flex items-center justify-between gap-4">
            <a href="/" class="text-xl font-bold text-indigo-600">ShardaCart</a>
            <form id="searchForm" action="/products/allProducts" method="get" class="hidden md:flex flex-1 max-w-xl">
              <input
                type="text"
                name="q"
                id="searchInput"
                placeholder="Search products"
                class="w-full rounded-l-lg border border-slate-300 px-3 py-2 focus:outline-none focus:border-indigo-500"
              />
              <button class="rounded-r-lg bg-slate-900 text-white px-4 py-2">Search</button>
            </form>
            <nav class="flex items-center gap-3 sm:gap-5 text-sm font-medium">
              <a href="/" class="text-slate-700 hover:text-indigo-600">Home</a>
              <% if (currentUser) { %>
              <% const isRetailer = currentUser.role === "retailer" || currentUser.role === "admin"; %>
              <% const isBuyer = currentUser.role === "buyer"; %>
              <% if (isRetailer) { %>
              <a href="/products/new" class="text-slate-700 hover:text-indigo-600">Add Product</a>
              <a href="/products/allProducts" class="text-slate-700 hover:text-indigo-600">My Products</a>
              <% } %>
              <% if (isBuyer) { %>
              <a href="/products/allProducts" class="text-slate-700 hover:text-indigo-600">Shop</a>
              <a href="/products/cart" class="text-slate-700 hover:text-indigo-600">Cart</a>
              <a href="/products/wishlist" class="text-slate-700 hover:text-indigo-600">
                Wishlist<% if (currentUser.wishlist && currentUser.wishlist.length) { %> (<%= currentUser.wishlist.length %>)<% } %>
              </a>
              <% } %>
              <span class="text-slate-500 hidden sm:inline">Hi, <%= currentUser.name %></span>
              <form action="/auth/logout" method="post" class="inline">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button type="submit" class="text-slate-700 hover:text-indigo-600">Logout</button>
              </form>
              <button
                type="button"
                class="theme-toggle"
                data-theme-toggle
                aria-label="Toggle dark mode"
                title="Toggle dark mode"
              >
                <span class="theme-toggle-track" aria-hidden="true">
                  <span class="theme-toggle-icons">
                    <span>&#9728;</span>
                    <span>&#9790;</span>
                  </span>
                  <span class="theme-toggle-thumb"></span>
                </span>
              </button>
              <% } else { %>
              <a href="/auth/login" class="text-slate-700 hover:text-indigo-600">Login</a>
              <a href="/auth/register" class="rounded-md bg-indigo-600 px-3 py-1.5 text-white hover:bg-indigo-700">Register</a>
              <button
                type="button"
                class="theme-toggle"
                data-theme-toggle
                aria-label="Toggle dark mode"
                title="Toggle dark mode"
              >
                <span class="theme-toggle-track" aria-hidden="true">
                  <span class="theme-toggle-icons">
                    <span>&#9728;</span>
                    <span>&#9790;</span>
                  </span>
                  <span class="theme-toggle-thumb"></span>
                </span>
              </button>
              <% } %>
            </nav>
          </div>
        </div>
      </header>
      <main class="site-main">
