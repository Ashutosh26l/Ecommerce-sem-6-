<%- include("partials/header", { title: "Cart" }) %>

<section class="max-w-6xl mx-auto px-4 sm:px-6 py-10">
  <%- include("partials/flash") %>
  <div class="relative overflow-hidden rounded-3xl bg-gradient-to-r from-slate-900 via-indigo-900 to-slate-900 p-6 sm:p-8 mb-8">
    <div class="absolute -top-12 -right-12 h-40 w-40 rounded-full bg-indigo-400/20 blur-2xl"></div>
    <div class="absolute -bottom-10 -left-10 h-36 w-36 rounded-full bg-cyan-300/20 blur-2xl"></div>
    <div class="relative flex items-center justify-between gap-4">
      <div>
        <p class="text-indigo-200 text-sm font-medium">Shopping Cart</p>
        <h1 class="text-3xl sm:text-4xl font-bold text-white mt-1">Your Items</h1>
      </div>
      <div class="rounded-2xl bg-white/10 border border-white/20 px-4 py-3 text-right">
        <p class="text-indigo-100 text-xs">Items</p>
        <p class="text-white text-2xl font-bold"><%= cartItems ? cartItems.length : 0 %></p>
      </div>
    </div>
  </div>

  <% if (cartItems && cartItems.length > 0) { %>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 space-y-4">
      <% cartItems.forEach(function(item) { %>
      <% const imageSrc = item.product.image || '/mobile.jpg'; %>
      <% const lineTotal = Number(item.product.price || 0) * Number(item.quantity || 0); %>
      <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-4 sm:p-5">
        <div class="flex gap-4 sm:gap-5">
          <img src="<%= imageSrc %>" alt="<%= item.product.name %>" class="h-24 w-24 rounded-xl object-cover border border-slate-200" />
          <div class="flex-1 min-w-0">
            <h2 class="text-lg font-semibold text-slate-900 truncate"><%= item.product.name %></h2>
            <p class="text-sm text-slate-500 mt-1">Unit price: &#8377; <%= item.product.price %></p>
            <div class="mt-3 flex items-center justify-between gap-3">
              <div class="flex items-center gap-2">
                <form method="POST" action="/products/<%= item.product._id %>/cart/update" class="inline-flex">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <input type="hidden" name="action" value="decrease" />
                  <button type="submit" class="h-8 w-8 rounded-md border border-slate-300 text-slate-700 hover:bg-slate-100">-</button>
                </form>
                <span class="inline-flex items-center rounded-full bg-indigo-50 text-indigo-700 px-3 py-1 text-sm font-medium">
                  Qty: <%= item.quantity %>
                </span>
                <form method="POST" action="/products/<%= item.product._id %>/cart/update" class="inline-flex">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <input type="hidden" name="action" value="increase" />
                  <button type="submit" class="h-8 w-8 rounded-md border border-slate-300 text-slate-700 hover:bg-slate-100">+</button>
                </form>
                <form
                  method="POST"
                  action="/products/<%= item.product._id %>/cart/remove"
                  class="inline-flex ml-2"
                  data-confirm-message="Remove this item from cart?"
                  data-confirm-cta="Remove"
                >
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button type="submit" class="text-sm font-medium text-rose-600 hover:text-rose-700">Remove</button>
                </form>
              </div>
              <p class="text-xl font-bold text-slate-900">&#8377; <%= lineTotal %></p>
            </div>
          </div>
        </div>
      </div>
      <% }); %>
    </div>

    <aside class="lg:col-span-1">
      <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-5 sticky top-24">
        <h3 class="text-xl font-bold text-slate-900">Order Summary</h3>
        <div class="mt-4 space-y-3 text-sm">
          <div class="flex items-center justify-between text-slate-600">
            <span>Subtotal</span>
            <span>&#8377; <%= total %></span>
          </div>
          <div class="flex items-center justify-between text-slate-600">
            <span>Shipping</span>
            <span class="text-emerald-600 font-medium">Free</span>
          </div>
          <div class="flex items-center justify-between text-slate-600">
            <span>Taxes</span>
            <span>Included</span>
          </div>
          <div class="border-t border-slate-200 pt-3 flex items-center justify-between">
            <span class="text-slate-900 font-semibold">Total</span>
            <span class="text-2xl font-bold text-indigo-700">&#8377; <%= total %></span>
          </div>
        </div>
        <a href="/products/allProducts" class="mt-5 block w-full text-center rounded-xl bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-3 transition-colors">
          Continue Shopping
        </a>
        <a
          href="/products/<%= cartItems[0].product._id %>/buy-now"
          data-animate-cta
          class="mt-3 block w-full text-center rounded-xl bg-emerald-600 hover:bg-emerald-700 text-white font-semibold py-3 transition-colors"
          data-smart-suggestion="Add ₹{{amount}} more for free delivery."
          data-checkout-threshold="499"
          data-current-total="<%= total %>"
        >
          Proceed to Checkout
        </a>
      </div>
    </aside>
  </div>
  <% } else { %>
  <div class="bg-white rounded-3xl border border-slate-200 shadow-sm p-8 sm:p-12 text-center">
    <div class="mx-auto h-16 w-16 rounded-full bg-indigo-100 text-indigo-600 flex items-center justify-center text-2xl font-bold">
      C
    </div>
    <h2 class="text-2xl font-bold text-slate-900 mt-4">Your cart is empty</h2>
    <p class="text-slate-500 mt-2">Looks like you have not added anything yet.</p>
    <a href="/products/allProducts" class="inline-block mt-6 rounded-xl bg-indigo-600 hover:bg-indigo-700 text-white font-semibold px-6 py-3 transition-colors">
      Browse Products
    </a>
  </div>
  <% } %>
</section>

<%- include("partials/footer") %>
